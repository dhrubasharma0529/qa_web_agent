# Copy this file to .env and fill in real values.
# .env is git-ignored. .env.example IS committed and serves as documentation.

# --- LLM / OpenAI ----------------------------------------------------------
OPENAI_API_KEY=sk-proj-REPLACE_ME
OPENAI_MODEL=gpt-4o-mini
LLM_MODEL=gpt-4o-mini

# --- LangSmith Observability (optional but recommended) --------------------
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=qa-web-agent
LANGSMITH_API_KEY=lsv2_pt_REPLACE_ME

# --- Browser backend -------------------------------------------------------
# Options: "playwright" | "webmcp"
BROWSER_BACKEND=playwright

# --- Cypress execution -----------------------------------------------------
# Headless on servers (no display). Headed mode requires Xvfb on Linux.
CYPRESS_HEADED=false
# Pause between steps (ms). 0 in production, 500 useful when debugging locally.
CYPRESS_STEP_DELAY_MS=0

# --- Checkpointer ----------------------------------------------------------
# Options: "memory" | "sqlite" | "postgres"
CHECKPOINTER=sqlite
SQLITE_DB_PATH=checkpoints.db
# POSTGRES_URI=postgresql://user:pass@localhost:5432/qa_web_agent

# --- Runtime flags ---------------------------------------------------------
BG_JOB_ISOLATED_LOOPS=true

# --- Deployment ------------------------------------------------------------
# Options: "cloud" | "local" (used by docker-compose)
TARGET_ENV=cloud
